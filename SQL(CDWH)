#CUSTOMER DATA WITH HEALTH CATEGORIES (SQL)
CREATE DATABASE SpiceConnect;
USE SpiceConnect;

CREATE TABLE customers (
    customer_id INT PRIMARY KEY,
    full_name VARCHAR(100),
    age INT,
    city VARCHAR(50),
    state VARCHAR(50),
    customer_type VARCHAR(20), -- Retail, Wholesale, Vendor
    health_conscious VARCHAR(3), -- Yes/No
    healthcare_condition VARCHAR(50), -- BP, Diabetes, None, Heart Issue
    bp_patient VARCHAR(3), -- Yes/No
    monthly_chilli_spend_rs DECIMAL(8,2),
    preferred_chilli_category VARCHAR(50) -- Guntur, Byadgi, Kashmiri, Bird's Eye, Organic
);


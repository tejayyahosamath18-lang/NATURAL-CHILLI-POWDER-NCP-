-- Sample analysis queries
SELECT 
    bp_patient, 
    AVG(monthly_chilli_spend_rs) AS avg_spend,
    COUNT(*) AS total_customers
FROM customers
GROUP BY bp_patient;

SELECT 
    preferred_chilli_category, 
    SUM(monthly_chilli_spend_rs) AS total_revenue
FROM customers
GROUP BY preferred_chilli_category
ORDER BY total_revenue DESC;

-- 5. Useful SQL Queries for your analysis
-- Top 5 cities with most BP patients buying NCP
SELECT TOP 5 City, COUNT(*) AS BP_Customer_Count 
FROM Customers WHERE IsHypertensive = 1 
GROUP BY City ORDER BY BP_Customer_Count DESC;

-- Most preferred product by elderly
SELECT PreferredProduct, COUNT(*) AS Preference_Count
FROM Customers WHERE Category = 'Elderly'
GROUP BY PreferredProduct ORDER BY Preference_Count DESC;

-- Total revenue by health condition
SELECT 
    CASE WHEN IsHypertensive = 1 THEN 'BP Patient' ELSE 'Non-BP' END AS HealthType,
    SUM(MonthlySpendINR) AS TotalRevenue
FROM Customers GROUP BY IsHypertensive;

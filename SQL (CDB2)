#SQL DATABASE - CUSTOMER DATA BASE & TYPES 
-- CREATE DATABASE NCP_Business;
-- USE NCP_Business;

-- 1. Customer Table (including BP patients & health conscious)
CREATE TABLE Customers (
    CustomerID INT PRIMARY KEY IDENTITY(1,1),
    FullName VARCHAR(100),
    Age INT,
    Gender VARCHAR(10),
    City VARCHAR(50),
    State VARCHAR(50),
    Category VARCHAR(20) CHECK (Category IN ('Elderly', 'BP_Patient', 'Health_Conscious', 'Organic_Buyer', 'Chef', 'General')),
    IsHypertensive BIT, -- 1 = BP patient, 0 = normal
    IsHealthConscious BIT,
    MonthlySpendINR DECIMAL(10,2),
    PreferredProduct VARCHAR(50),
    RegisteredDate DATE
);

-- 2. Product Table
CREATE TABLE Products (
    ProductID INT PRIMARY KEY,
    ProductName VARCHAR(50),
    Category VARCHAR(30), -- 'Chilli', 'Tamarind', 'Chutney', 'Sweet', 'Mango'
    BaseIngredient VARCHAR(50),
    IsZeroSalt BIT,
    PriceINR DECIMAL(10,2)
);

-- 3. Sales Transaction Table
CREATE TABLE Sales (
    SaleID INT PRIMARY KEY IDENTITY(1,1),
    CustomerID INT FOREIGN KEY REFERENCES Customers(CustomerID),
    ProductID INT FOREIGN KEY REFERENCES Products(ProductID),
    Quantity INT,
    SaleDate DATE,
    DiscountPercent DECIMAL(5,2),
    TotalAmount DECIMAL(10,2)
);

